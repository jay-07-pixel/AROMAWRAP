# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file with real credentials.

# Admin login email (user with ADMIN role in the database)
VITE_ADMIN_EMAIL=

# Express API (optional in dev — Vite proxies /api and /uploads to localhost:3001)
VITE_API_URL=

# UPI checkout (shown on payment QR)
VITE_MERCHANT_UPI_ID=
VITE_MERCHANT_NAME=AromaWrap
