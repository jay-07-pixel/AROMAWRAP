# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file with real credentials.

# Firebase (Firebase Console → Project settings → Your apps → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Admin login email (must match a Firebase Auth user; set role in Firestore or sign in once)
VITE_ADMIN_EMAIL=

# UPI checkout (shown on payment QR — configure in Firebase/hosting env for production)
VITE_MERCHANT_UPI_ID=
VITE_MERCHANT_NAME=AromaWrap
