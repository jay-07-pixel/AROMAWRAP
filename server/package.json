{
  "name": "aromawrap-server",
  "version": "1.0.0",
  "private": true,
  "description": "AromaWrap Express + Prisma + MySQL API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
