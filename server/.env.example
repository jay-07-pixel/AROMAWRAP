# Server
NODE_ENV=development
PORT=3001

# MySQL (Prisma)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/aromawrap"

# Session (express-session)
SESSION_SECRET=change-me-to-a-long-random-secret
SESSION_NAME=aromawrap.sid

# CORS — comma-separated origins (frontend not connected yet)
CORS_ORIGIN=http://localhost:8080

# File uploads (Multer destination)
UPLOAD_DIR=src/uploads
